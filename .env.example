# PostgreSQL
DATABASE_URL=postgresql://momentum:momentum@localhost:5432/momentum?schema=public
DATABASE_REPLICA_URL=postgresql://momentum:momentum@localhost:5433/momentum?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# Kafka
KAFKA_BROKERS=localhost:9092

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=1h

# Services
API_GATEWAY_PORT=3000
EVENT_SERVICE_PORT=3001
BOOKING_SERVICE_PORT=3002
SEARCH_SERVICE_PORT=3003

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RESERVE_RATE_LIMIT_MAX=10

# Reservation
RESERVATION_TTL_SECONDS=420

# Anti-Bot
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=
WAITING_ROOM_THRESHOLD_RPS=1000
QUEUE_TOKEN_SECRET=your-queue-token-secret

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
